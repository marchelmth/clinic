---
import api from "../services/api";
let doctors = [];

try {
	const { data: response } = await api.get("/api/doctors");
	doctors = response?.data ?? [];
} catch (error) {
	console.error(
		"Error fetching doctors:",
		error instanceof Error ? error.message : error,
	);
	doctors = [];
}
---

<p class="h2 fw-bold text-dark mb-0">{doctors.length}</p>
