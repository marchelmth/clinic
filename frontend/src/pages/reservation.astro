---
import "../styles/global.css";
import Header from "../components/header.astro";
import Layouts from "../layouts/layouts.astro";
const title = "Klinik Sehat | Reservasi";
---

<Layouts {title}>
    <!-- Header -->
    <Header Page={title.split(" | ")[1]} cssClass="sticky-top"s />

    <div
        class="container font-iosevka min-vh-100 d-flex align-items-center py-4"
    >
        <div class="row justify-content-center w-100 mb-3 mb-md-5">
            <div class="col-11 col-sm-8 col-md-6 col-lg-5 col-xl-4 ms-3">
                <div class="card border-1 rounded-4 shadow-sm">
                    <div class="card-body p-3 p-md-4">
                        <h5 class="text-uppercase text-center mb-3">
                            Buat Reservasi
                        </h5>
                        <form>
                            <div class="mb-3">
                                <label
                                    class="form-label fw-medium"
                                    for="peserta">Peserta</label
                                >
                                <input
                                    type="text"
                                    id="peserta"
                                    class="form-control bg-body-secondary"
                                />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-medium" for="poli"
                                    >Poli</label
                                >
                                <select
                                    name="poli"
                                    id="poli"
                                    class="form-select bg-body-secondary"
                                >
                                    <option value="">Pilih Poli</option>
                                    <option value="Poli Umum">Poli Umum</option>
                                    <option value="Poli Anak">Poli Anak</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-medium" for="hari"
                                    >Hari</label
                                >
                                <select
                                    name="hari"
                                    id="hari"
                                    class="form-select bg-body-secondary"
                                >
                                    <option value="">Pilih Hari</option>
                                    <option value="Hari Ini"
                                        >Hari Ini (2026-04-01)</option
                                    >
                                    <option value="Besok"
                                        >Besok (2026-04-02)</option
                                    >
                                </select>
                            </div>

                            <div class="mb-4">
                                <label
                                    class="form-label fw-medium"
                                    for="keluhan">Keluhan</label
                                >
                                <textarea
                                    id="keluhan"
                                    rows="3"
                                    placeholder="Silakan isi keluhan..."
                                    class="form-control bg-body-secondary"
                                ></textarea>
                            </div>

                            <div class="d-grid">
                                <a
                                    href="queue.html"
                                    class="btn btn-success btn-lg text-white"
                                    >Simpan</a
                                >
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</Layouts>
