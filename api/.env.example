APP_NAME="Clinic API"
APP_URL=http://localhost:3000
APP_ENV=development
APP_KEY=base64:your-app-key-here

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=clinic
DB_USERNAME=root
DB_PASSWORD=root

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your-mailtrap-username
MAIL_PASSWORD=your-mailtrap-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="your-mailtrap-username"
MAIL_FROM_NAME="${APP_NAME}"